meta {
  name: getOrders
  type: http
  seq: 1
}

get {
  url: http://localhost:3000/api/orders?status=1
  body: none
  auth: inherit
}

params:query {
  status: 1
  ~product_id: 2
}

docs {
  ## GET /api/orders
  
  **Description**  
  Returns all orders for the currently authenticated user.  
  Admins receive **all orders**, regular users only their own.
  
  ---
  
  ### Request
  
  - **Method:** `GET`
  - **Endpoint:** `/api/orders`
  - **Authentication:** Required (via accessToken cookie)
  
  ---
  
  ### Permissions
  
  | Role       | Access type             |
  |------------|--------------------------|
  | Admin      | All orders               |
  | Registered | Only own orders          |
  
  ---
  
  ### Successful response
  
  | Status | Description         |
  |--------|---------------------|
  | 200    | Orders returned     |
  
  ```json
  {
    "success": true,
    "orders": [
      {
        "id": 12,
        "user_id": 3,
        "items": [
          {
            "product_id": 7,
            "quantity": 2,
            "price": 29.99
          }
        ],
        "status": "pending",
        "created_at": "2025-06-26T09:32:45.000Z"
      }
    ]
  }
  ```
  
  ---
  
  ### Error responses
  
  | Status | Message                          | Condition                                 |
  |--------|----------------------------------|--------------------------------------------|
  | 401    | `Authentication required`        | No or invalid accessToken cookie           |
  | 403    | `Email not verified`             | Logged-in user has not verified email      |
  | 500    | `Error fetching orders`          | Internal DB or server failure              |
  
  ---
  
  ### Notes
  
  - The list is filtered automatically depending on the user's role.
  - This endpoint requires the user to be verified (`is_verified = true`).
  - Orders include full product and quantity breakdown.
  
}
