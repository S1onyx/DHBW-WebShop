meta {
  name: getAllProducts with params
  type: http
  seq: 2
}

get {
  url: http://localhost:3000/api/products?minPrice=100&maxPrice=300&name=t&inStock=true&sort=price&order=asc
  body: none
  auth: none
}

params:query {
  minPrice: 100
  maxPrice: 300
  name: t
  inStock: true
  sort: price
  order: asc
  ~category: 2
}
